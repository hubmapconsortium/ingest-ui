  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:compat": "NODE_OPTIONS='--trace-deprecation' vite build",
    "build:tags": "env-cmd -f envs/env.tags vite build",
    "build:sourcemaps": "GENERATE_SOURCEMAP=true vite build",
    "lint": "eslint --ext .js,.jsx src vite.config.mjs",
    "upload-sourcemaps": "node ./scripts/upload-sourcemaps.js",
    "upload-sourcemaps:dry-run": "node ./scripts/upload-sourcemaps.js --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "cypress:open": "cypress open"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
