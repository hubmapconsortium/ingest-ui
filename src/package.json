{
  "name": "ingest-ui",
  "version": "2.6.66",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@datadog/browser-logs": "^7.4.0",
    "@emotion/styled": "^11.6.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@mui/icons-material": "^5.4.2",
    "@mui/lab": "^5.0.0-alpha.120",
    "@mui/material": "^5.2.8",
    "@mui/x-data-grid": "7.23.0",
    "@mui/x-date-pickers": "^7.1.0",
    "axios": "^1.18.1",
    "bootstrap": "^5.2.0-beta1",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "elastic-builder": "^2.16.0",
    "env-cmd": "^11.0.0",
    "papaparse": "^5.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-idle-timer": "^4.6.4",
    "react-router-dom": "^7.18.0",
    "react-spinners": "0.17.0",
    "react-tooltip": "4.2.13"
  },
  "devDependencies": {
    "@datadog/datadog-ci": "^5.19.0",
    "@eslint/js": "^9.21.0",
    "@vitejs/plugin-react": "^6.0.3",
    "cypress": "^13.17.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-react": "^7.37.4",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "immer": "9.0.7",
    "ansi-html": "https://registry.yarnpkg.com/ansi-html-community/-/ansi-html-community-0.0.8.tgz",
    "ansi-regex": "5.0.1",
    "nth-check": "2.0.1",
    "glob-parent": "6.0.1",
    "browserslist": "4.18.1"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:compat": "NODE_OPTIONS='--trace-deprecation' vite build",
    "build:tags": "env-cmd -f envs/env.tags -- vite build",
    "build:sourcemaps": "GENERATE_SOURCEMAP=true vite build",
    "lint": "eslint --ext .js,.jsx src vite.config.mjs",
    "upload-sourcemaps": "node ./scripts/upload-sourcemaps.js",
    "upload-sourcemaps:dry-run": "node ./scripts/upload-sourcemaps.js --dry-run",
    "test:all": "npm run test:v && npm run test:c",
    "test:c": "node ./scripts/test-cypress.js",
    "test:v": "vitest run",
    "verify:production-routing": "node ./scripts/verify-production-routing.js",
    "verify:react19": "npm run lint && npm run test:v && npm run build && npm run build:tags && npm run verify:production-routing",
    "verify:docker-config": "cd ../docker && ./docker-development.sh config",
    "verify:docker-build": "cd ../docker && ./docker-development.sh build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
