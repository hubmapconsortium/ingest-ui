# Example environment for local development.
#
# Copy this file to `.env.local` or the environment-specific `.env.*` file you
# need, then fill in deployment-specific values. Do not commit real secrets.
#
# Vite note: do not set NODE_ENV in .env files. Vite sets it from the command.

# Local dev server
PORT=8585
GENERATE_SOURCEMAP=true

# Optional Cypress authenticated smoke tests.
# Keep real session data local and untracked; this example JSON is intentionally
# fake. Cypress is opened with `npm run test:c`.
CYPRESS_AUTH_INFO='{"name":"Example User","email":"example.user@example.org","globus_id":"00000000-0000-0000-0000-000000000000","auth_token":"example-auth-token","transfer_token":"example-transfer-token","groups_token":"example-groups-token"}'
CYPRESS_AUTH_SEARCH_KEYWORD='HBM000.TEST.000'

# App environment label used by the UI/logging layer.
REACT_APP_NODE_ENV='local'

# Backend API services
REACT_APP_DATAINGEST_API_URL='https://ingest-api.dev.hubmapconsortium.org'
REACT_APP_ENTITY_API_URL='https://entity-api.dev.hubmapconsortium.org'
REACT_APP_SEARCH_API_URL='https://search-api.dev.hubmapconsortium.org/v3'
REACT_APP_UBKG_API_URL='https://ontology-api.dev.hubmapconsortium.org'

# Related HuBMAP applications
REACT_APP_URL='http://localhost:8585'
REACT_APP_PORTAL_URL='https://portal.dev.hubmapconsortium.org/'
REACT_APP_PROFILE_URL='https://profile.hubmapconsortium.org'
REACT_APP_INGEST_BOARD_URL='https://ingest-board.dev.hubmapconsortium.org/'

# RUI / organ assets
REACT_APP_RUI_BASE_URL='https://cdn.humanatlas.io/ui/ccf-rui/'
REACT_APP_ORGAN_ICON_URL='https://raw.githubusercontent.com/hubmapconsortium/ccf-ui/refs/heads/main/projects/ccf-rui/src/assets/icons/organs/'

# Group names and IDs.
# These are identifiers rather than passwords, but keep environment-specific
# production values out of the example template.
REACT_APP_HUBMAP_DATA_ADMIN_GROUP='HuBMAP-data-admin'
REACT_APP_READ_ONLY_GROUP_ID='00000000-0000-0000-0000-000000000000'
REACT_APP_DATA_ADMIN='00000000-0000-0000-0000-000000000000'
REACT_APP_DATA_CURATOR='00000000-0000-0000-0000-000000000000'

# Entity API query customization
REACT_APP_DATASET_QUERY_PARAM='?exclude=direct_ancestors.files,files'

# Request timeout overrides, in milliseconds.
REACT_APP_AXIOS_TIMEOUT_MS='10000'
REACT_APP_SEARCH_API_TIMEOUT_MS='6000'

# Datadog browser logging / RUM.
# Leave blank for local development unless you intentionally want browser logs
# sent to Datadog. Treat these values as sensitive environment config.
REACT_APP_DATADOG_APP_ID=''
REACT_APP_DATADOG_CLIENT_TOKEN=''
REACT_APP_DD_SERVICE='site:ingest_ui'
REACT_APP_DD_HOST='local'

# Optional local debug helper for doglog.
REACT_APP_DOGLOG_LOCAL_DUMP='0'

# Datadog sourcemap upload settings.
# DATADOG_API_KEY is a CI/deployment secret; never commit a real value.
DATADOG_API_KEY=''
DATADOG_SITE='datadoghq.com'
DD_SERVICE='ingest-ui'
DD_ENV='local'
DD_VERSION=''
DD_MINIFIED_PATH_PREFIX='/static/js'

# Legacy/optional local polling knob. Not required by Vite, but harmless if
# your local environment still expects it.
WATCHPACK_POLLING=true
